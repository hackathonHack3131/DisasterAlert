# Copy to backend/.env and frontend/.env — never commit real secrets

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/disaster_db?retryWrites=true&w=majority

SERVER_PORT=8081
JWT_SECRET=your-32-char-minimum-secret-key-here
CORS_ORIGINS=http://localhost:5173

# Brevo SMTP (recommended) or Gmail
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_smtp_key
MAIL_FROM=your@email.com

GMAIL_USER=
GMAIL_APP_PASSWORD=

OPENWEATHER_API_KEY=
NASA_FIRMS_MAP_KEY=
GOOGLE_API_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
